PORT=3001
NODE_ENV=production
SQLITE_DB_PATH=/data/undiscover.db
UPLOAD_DIR=/data/uploads
MAX_AUDIO_UPLOAD_MB=500
SEED_DEMO_DATA=false
PURGE_DEMO_DATA=true
ADMIN_EMAIL=admin@undisc0ver.com
ADMIN_PASSWORD=change_admin_password
ADMIN_NAME=Undiscover Admin
PUBLIC_SITE_URL=https://undisc0ver.com
AUTH_STATE_SECRET=change_oauth_state_secret_min32chars
AUDIO_TOKEN_SECRET=change_audio_token_secret_min32chars
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://undisc0ver.com/api/auth/google/callback

# Stripe (paiements — https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_LABEL=price_...

# Resend (emails transactionnels — https://resend.com/api-keys)
RESEND_API_KEY=re_...
EMAIL_FROM=Undisc0ver <noreply@undisc0ver.com>

COPYRIGHT_SCAN_PROVIDER=manual
COPYRIGHT_TAKEDOWN_EMAIL=copyright@undisc0ver.com
COPYRIGHT_BLOCK_THRESHOLD=80
COPYRIGHT_REVIEW_THRESHOLD=45
