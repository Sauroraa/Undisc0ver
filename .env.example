PORT=3001
NODE_ENV=production
SQLITE_DB_PATH=/data/undiscover.db
UPLOAD_DIR=/data/uploads
MAX_AUDIO_UPLOAD_MB=500
SEED_DEMO_DATA=false
PURGE_DEMO_DATA=true
ADMIN_EMAIL=admin@undisc0ver.com
ADMIN_PASSWORD=change_admin_password
ADMIN_NAME=Undiscover Admin
PUBLIC_SITE_URL=https://undisc0ver.com
AUTH_STATE_SECRET=change_oauth_state_secret
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://undisc0ver.com/api/auth/google/callback

MARIADB_ROOT_PASSWORD=change_root_me
MARIADB_DATABASE=undiscover
MARIADB_USER=undiscover
MARIADB_PASSWORD=change_me

COPYRIGHT_SCAN_PROVIDER=manual
COPYRIGHT_TAKEDOWN_EMAIL=copyright@undisc0ver.com
COPYRIGHT_BLOCK_THRESHOLD=80
COPYRIGHT_REVIEW_THRESHOLD=45
